# --------------------------------------------------------------
#  Nanobot – Full configuration (all keys & secrets in one file)
#  Copy this file to .env and fill in the required values.
#  Gmail example is provided for the email channel.
# --------------------------------------------------------------

# ── Nanobot Model ────────────────────────────────────────────────
NANOBOT_MODEL=minimaxai/minimax-m2.7   # default model

# ── Core API Keys ────────────────────────────────────────────────
TELEGRAM_TOKEN=                       # Telegram bot token (@BotFather)

# LLM provider: "nvidia" or "openrouter" (default: nvidia)
# Controls which API key and endpoint are used for inference.
LLM_PROVIDER=nvidia

# ── NVIDIA NIM / NeMo ────────────────────────────────────────────
# Required when LLM_PROVIDER=nvidia (or unset, since nvidia is the default)
NVIDIA_API_KEY=                       # NVIDIA NIM / NeMo API key

# ── OpenRouter (alternative provider) ────────────────────────────
# Required when LLM_PROVIDER=openrouter
# Sign up at https://openrouter.ai/ and get your key from the dashboard.
OPENROUTER_API_KEY=                   # OpenRouter API key
PORT=10000                            # health‑check / dashboard port

# ── rclone (optional – cloud storage backup) ────────────────────
# Encode your entire rclone.conf file to base64 and paste it here:
#   Linux/macOS:  base64 -w 0 rclone.conf
#   PowerShell:   [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((Get-Content -Raw rclone.conf)))
# Example (truncated):
# RCLONE_CONFIG_BASE64=[willowtales]\ntype = drive\nclient_id = xxxxx\n...
RCLONE_CONFIG_BASE64=

# ── Gmail IMAP (inbound) ────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993                         # optional, default 993 (Gmail requires SSL)
IMAP_USERNAME=your.email@gmail.com
IMAP_PASSWORD=your_gmail_app_password  # Use a Gmail App Password, NOT your regular password
IMAP_MAILBOX=INBOX                    # optional, default INBOX
IMAP_USE_SSL=true                     # optional, default true

# ── Gmail SMTP (outbound) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587                         # optional, default 587 (STARTTLS)
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_gmail_app_password  # Same App Password as above
SMTP_USE_TLS=true                     # optional, default true
SMTP_USE_SSL=false                    # optional, default false
FROM_ADDRESS=your.email@gmail.com    # optional – shown as sender

# ── Behaviour tweaks (all optional) ──────────────────────────────
AUTO_REPLY_ENABLED=true               # reply to inbound mail automatically
POLL_INTERVAL=30                      # seconds between IMAP polls
MARK_SEEN=true                        # mark fetched mails as read
MAX_BODY_CHARS=12000                  # truncate long messages
SUBJECT_PREFIX="Re: "                 # prefix for reply subjects
VERIFY_DKIM=true                      # enforce DKIM verification
VERIFY_SPF=true                       # enforce SPF verification
ALLOWED_ATTACHMENT_TYPES=["*"]        # or ["application/pdf","image/*"]
MAX_ATTACHMENT_SIZE=2000000           # bytes, default 2 MiB
MAX_ATTACHMENTS_PER_EMAIL=5           # max attachments per inbound mail